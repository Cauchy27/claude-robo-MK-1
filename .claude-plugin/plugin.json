{
  "name": "claude-robo-MK-1",
  "description": "日本語ロボ口調プラグイン。敬語・助詞・フィラーを削減して出力トークンを30-50%削減する。技術的正確性は完全維持。",
  "version": "0.1.0",
  "author": {
    "name": "Cauchy27",
    "url": "https://github.com/Cauchy27"
  },
  "homepage": "https://github.com/Cauchy27/claude-robo-MK-1",
  "repository": "https://github.com/Cauchy27/claude-robo-MK-1",
  "license": "MIT",
  "keywords": ["token-reduction", "japanese", "terse", "robo", "claude-code"],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/activate.sh\"",
            "timeout": 5,
            "statusMessage": "claude-robo-MK-1 起動シテイル..."
          }
        ]
      }
    ]
  }
}
